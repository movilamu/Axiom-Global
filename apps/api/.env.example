# Server
PORT=3001
NODE_ENV=development

# Database - PostgreSQL connection string (Supabase provides this)
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://user:password@host:5432/postgres?schema=public

# Supabase
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT - Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis - Upstash Redis (free tier at https://upstash.com)
# Get from: Upstash Console > Redis > Details
REDIS_URL=redis://default:password@host:port

# Resend - Email (free tier at https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Twilio Verify - OTP (free trial at https://twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Test Mode (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Razorpay Test Mode (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret

# Cloudinary (free tier at https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CoinGecko - Free, no API key needed (rate limit 10-30/min)
# EXCHANGE_RATE_API - Free at https://www.exchangerate-api.com/
